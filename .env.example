PORT=4000

# Copy from Render → side-quest-db → Connect
# External URL (for your Mac / migrations):
#   postgresql://USER:PASSWORD@HOST/side_quest_db
# (Render often uses underscores: side_quest_db — copy exactly from Connect tab)

DATABASE_URL=postgresql://USER:PASSWORD@HOST/side_quest_db

JWT_SECRET=replace-with-openssl-rand-hex-32

# Google sign-in — Web client ID (required) + iOS/Android if using native clients
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id.apps.googleusercontent.com
OPENAI_API_KEY=sk-your-key-here
NODE_ENV=development

# Optional: real verification emails via Resend (https://resend.com)
# RESEND_API_KEY=re_xxxx
# FROM_EMAIL=Side Quest <noreply@yourdomain.com>
# APP_VERIFY_URL=sidequest://verify

# Admin key for GET /quest-submissions
# ADMIN_API_KEY=your-secret-admin-key
